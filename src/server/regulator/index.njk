{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "epr-regulator-frontend"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-body" data-testid="regulator-page-body">
        <p>This is the regulator page, accessible only to authenticated users.</p>
      </div>

      {{ govukButton({
        text: "Log out",
        href: "/logout",
        classes: "govuk-button--secondary"
      }) }}
    </div>
  </div>

{% endblock %}
